generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================================================
// ⚠️ SUAS TABELAS ANTIGAS
// ========================================================
model TabelaPreco {
  id        String   @id @default(cuid())
  fonte     String   @unique
  dados     Json
  updatedAt DateTime @updatedAt
}

// 🔥 NOVA TABELA: CACHE DE INSPECT (DNA DA SKIN)
// Guardamos o Float/Pattern para nunca mais gastar tokens na mesma skin
model InspectCache {
  id          String   @id @default(cuid())
  inspectLink String   @unique @db.Text
  float       Float?
  pattern     Int?
  phase       String?
  fade        Float?
  createdAt   DateTime @default(now())
}

// --- MODELOS DE AUTENTICAÇÃO (NEXTAUTH) ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  password      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  plan          String    @default("FREE") 
  telefone      String?   
  
  accounts      Account[]
  sessions      Session[]
  itens         Item[]    
}

// --- O SEU COFRE (SKINS & INVENTÁRIO) ---
model Item {
  id          String   @id @default(cuid())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  nome        String   
  tipo        String?  
  condicao    String?  
  imagem      String?  @db.Text
  quantidade  Int      @default(1)
  
  valorPago   Decimal  @db.Decimal(10, 2)
  dataCompra  DateTime @default(now())
  status      String   @default("EM_ESTOQUE") 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}